# Chave do Google AI Studio para leitura de imagens de escala (Gemini 2.5 Flash)
# Obtenha gratuitamente em: https://aistudio.google.com/apikey
# ATENÇÃO: esta chave fica embutida no bundle JS — configure cota diária no Google AI Studio
VITE_GOOGLE_AI_API_KEY=AIza...

# Supabase — obtenha em: https://supabase.com/dashboard/project/_/settings/api
VITE_SUPABASE_URL=https://<seu-projeto>.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# Feature Flags — defina como 'false' para desligar (padrão: true / ativo)
# VITE_PERSIST_TO_SUPABASE=false
# VITE_REQUIRE_AUTH=false
# VITE_LOAD_FROM_DB=false
